<?xml version="1.0"?>
<ruleset name="TomTroc">
    <description>TomTroc coding standard</description>

    <rule ref="PSR12"/>

    <arg name="extensions" value="php"/>
    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="report" value="full"/>
    

    <file>src</file>
    <file>tests</file>
    <file>public</file>

    <exclude-pattern>vendor/*</exclude-pattern>
</ruleset>